    {
      "id": "cse-evs", "name": "EVS", "code": "",
      "branch": "cse", "year": 1, "semester": 2,
      "syllabus": "",
      "syllabusData": {
        "courseCode": "BTCSEAI EVS",
        "courseTitle": "Environmental Science",
        "lectureHours": "2L:0T:0P",
        "credits": 2,
        "courseOutcomes": [
          { "id": "CO1", "description": "Understand the multidisciplinary nature and fundamental concepts of the environment." },
          { "id": "CO2", "description": "Identify major types of natural resources, biodiversity, and the importance of their conservation." },
          { "id": "CO3", "description": "Analyze various forms of environmental pollution and explore suitable control measures." },
          { "id": "CO4", "description": "Understand and apply concepts related to sustainable development, EIA, and environmental legislation." },
          { "id": "CO5", "description": "Demonstrate awareness of global environmental issues, ethics, and the role of technology in monitoring." }
        ],
        "coPoMapping": [
          { "co": "CO1", "po": { "1": 3, "2": 2, "3": null, "4": null, "5": 1, "6": 2, "7": 3, "8": 2, "9": 1, "10": 1, "11": null, "12": 2 }, "pso": { "O1": 2, "O2": null, "O3": null } },
          { "co": "CO2", "po": { "1": 2, "2": 2, "3": 1, "4": null, "5": 1, "6": 2, "7": 3, "8": 2, "9": 1, "10": null, "11": null, "12": 2 }, "pso": { "O1": 2, "O2": 1, "O3": null } },
          { "co": "CO3", "po": { "1": 3, "2": 3, "3": 2, "4": 1, "5": 2, "6": 3, "7": 3, "8": 2, "9": 1, "10": 1, "11": null, "12": 3 }, "pso": { "O1": 2, "O2": 2, "O3": null } },
          { "co": "CO4", "po": { "1": 2, "2": 3, "3": 2, "4": 2, "5": 2, "6": 3, "7": 2, "8": 3, "9": 2, "10": 1, "11": null, "12": 3 }, "pso": { "O1": 2, "O2": 1, "O3": null } },
          { "co": "CO5", "po": { "1": 2, "2": 2, "3": 1, "4": 1, "5": 1, "6": 3, "7": 3, "8": 3, "9": 2, "10": 1, "11": null, "12": 3 }, "pso": { "O1": 2, "O2": 1, "O3": null } }
        ],
        "referenceBooks": [
          "Erach Bharucha, Textbook of Environmental Studies for Undergraduate Courses, Universities Press.",
          "Benny Joseph, Environmental Studies, Tata McGraw Hill.",
          "Subrat Roy, Environmental Science (AICTE Prescribed Textbook), Khanna Publishers.",
          "Anubha Kaushik and C.P. Kaushik, Environmental Studies, New Age International."
        ],
        "teachingStrategies": [
          "Interactive lectures and real-world case studies.",
          "Field surveys and eco-audits.",
          "Group discussions and debates on environmental ethics.",
          "Audio-visual presentations and document-based assessments."
        ],
        "assessmentMethods": [
          "Internal Assessment: 40 Marks (Assignments, Case Studies, Class Tests, Attendance).",
          "Semester Exam: 60 Marks (Theory only).",
          "Total: 100 Marks."
        ],
        "internalMarks": 40,
        "semesterMarks": 60
      },
      "units": [
        {
          "number": 1,
          "title": "Multidisciplinary Nature of Environmental Studies & Natural Resources",
          "topics": ["Definition, scope and importance of environmental studies", "Components of environment", "Renewable and non-renewable resources", "Forest, water, mineral, food, energy, land resources", "Associated problems and conservation practices"],
          "hours": 6,
          "playlist": "", "notes": "", "pyqs": ""
        },
        {
          "number": 2,
          "title": "Ecosystems and Biodiversity",
          "topics": ["Ecosystem structure, function and types", "Food chains, food webs and ecological pyramids", "Biodiversity definition, types and value", "India as a mega-diversity nation", "Threats to biodiversity and conservation strategies"],
          "hours": 6,
          "playlist": "", "notes": "", "pyqs": ""
        },
        {
          "number": 3,
          "title": "Environmental Pollution",
          "topics": ["Air, water, soil and noise pollution", "Causes, effects and control measures", "Solid waste management", "Role of individuals in pollution control", "Public health aspects and disaster management basics"],
          "hours": 6,
          "playlist": "", "notes": "", "pyqs": ""
        },
        {
          "number": 4,
          "title": "Social Issues, Sustainable Development & Environmental Legislation",
          "topics": ["Sustainable development goals", "Climate change, global warming and ozone depletion", "Related treaties", "Environmental Protection Act, Water Act, Air Act", "Wildlife and Forest Conservation Acts", "Role of NGOs and public awareness campaigns"],
          "hours": 6,
          "playlist": "", "notes": "", "pyqs": ""
        },
        {
          "number": 5,
          "title": "Environmental Impact Assessment and Role of IT",
          "topics": ["EIA process: screening, scoping, data collection and evaluation", "Environmental Management Plan", "Environmental ethics and green campus initiatives", "Use of information technology and GIS in environmental monitoring"],
          "hours": 6,
          "playlist": "", "notes": "", "pyqs": ""
        }
      ],
      "pyqs": { "sessional": "", "semester": "" }
    },
